# Get your API key at https://resend.com/api-keys (free tier is enough for a portfolio form)
RESEND_API_KEY=re_your_api_key_here

# Where contact form submissions get sent
CONTACT_TO_EMAIL=hello@donden.my

# Sender address. Leave as-is to use Resend's shared test sender (works instantly,
# but only delivers to the email you signed up to Resend with). Once you verify
# your own domain in the Resend dashboard, change this to something like:
# "Don's Portfolio <hello@donden.my>"
CONTACT_FROM_EMAIL=onboarding@resend.dev
